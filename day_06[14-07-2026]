1.sqrtx

int mySqrt(int x) {
    int low = 0, high = x, ans = -1;

    while (low <= high) {
        long long mid = (low + high) / 2;
        long long midsq = mid * mid;

        if (midsq == x)
            return mid;
        else if (midsq > x)
            high = mid - 1;
        else {
            ans = mid;
            low = mid + 1;
        }
    }

    return ans;
}


2. power of three 

#include <stdbool.h>

bool isPowerOfThree(int n) {
    if (n <= 0) return false;
    while (n % 3 == 0) {
        n /= 3;
    }
    return n == 1;
}
